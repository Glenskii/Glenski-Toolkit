{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Audit Manifest - Universal Audit spec v2.2, Sections 5 and 17",
  "type": "object",
  "required": [
    "schema_version", "spec_version", "catalog_version", "audit_id", "product",
    "audit_type", "tier", "profile", "environment", "access_level",
    "assurance_objective", "version_context", "scope", "authorization", "dates"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "spec_version": { "const": "2.2" },
    "catalog_version": { "type": "string" },
    "audit_id": { "type": "string", "pattern": "^AUD-[A-Z0-9]+-\\d{8}-\\d{3}$" },
    "product": {
      "type": "object",
      "required": ["name", "owner"],
      "properties": { "name": { "type": "string" }, "owner": { "type": "string" } }
    },
    "audit_type": {
      "enum": ["document", "source", "black-box", "grey-box", "full-stack", "release", "focused"]
    },
    "tier": { "enum": ["rapid", "standard", "deep"] },
    "profile": { "enum": ["P1", "P2", "P3", "P4", "P5", "P6"] },
    "profile_modifiers": { "type": "array", "items": { "type": "string" } },
    "environment": { "enum": ["local", "development", "staging", "production", "mixed"] },
    "access_level": {
      "enum": ["none", "read-only", "test-user", "privileged-test-user", "administrator", "infrastructure", "other"]
    },
    "assurance_objective": {
      "enum": ["advisory", "release-decision", "customer-assurance", "internal-control",
               "regulatory-support", "acquisition-review", "other"]
    },
    "version_context": {
      "type": "object",
      "required": ["commit_or_build"],
      "properties": {
        "commit_or_build": { "type": "string" },
        "release_id": { "type": ["string", "null"] },
        "urls": { "type": "array", "items": { "type": "string" } }
      }
    },
    "scope": {
      "type": "object",
      "required": ["included", "excluded"],
      "properties": {
        "included": { "type": "array", "items": { "type": "string" } },
        "excluded": { "type": "array", "items": { "type": "string" } }
      }
    },
    "authorization": {
      "type": "object",
      "required": ["reference", "active_testing_authorized"],
      "properties": {
        "reference": { "type": "string" },
        "active_testing_authorized": { "type": "boolean" }
      }
    },
    "dates": {
      "type": "object",
      "required": ["start", "end"],
      "properties": {
        "start": { "type": "string", "format": "date" },
        "end": { "type": "string", "format": "date" },
        "time_box": { "type": ["string", "null"] }
      }
    },
    "previous_audit_id": { "type": ["string", "null"] },
    "limitations": { "type": "array", "items": { "type": "string" } }
  }
}
