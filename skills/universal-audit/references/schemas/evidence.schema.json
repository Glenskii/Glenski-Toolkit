{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Evidence Record - Universal Audit spec v2.2, Section 8.2",
  "type": "object",
  "required": [
    "schema_version", "audit_id", "evidence_id", "evidence_class", "collected_at",
    "collected_by", "version_context", "location", "method", "excerpt"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "audit_id": { "type": "string" },
    "evidence_id": { "type": "string", "pattern": "-E\\d{3}$" },
    "evidence_class": {
      "enum": ["CODE", "CONFIG", "RUNTIME", "NETWORK", "DATA", "PIPELINE",
               "OPERATIONS", "DOCUMENT", "TOOL", "INTERVIEW", "INFERRED"]
    },
    "collected_at": { "type": "string", "format": "date-time" },
    "collected_by": { "type": "string" },
    "version_context": {
      "type": "object",
      "required": ["commit_or_build", "environment"],
      "properties": {
        "commit_or_build": { "type": "string" },
        "environment": { "type": "string" }
      }
    },
    "location": {
      "type": "string",
      "description": "File:line, endpoint, screen, config key, log reference, or artifact location."
    },
    "method": { "type": "string", "description": "Command or collection method, reproducible." },
    "excerpt": { "type": "string", "description": "Sanitized. No secrets, personal data, or unsafe exploit material." },
    "integrity_ref": { "type": ["string", "null"], "description": "Checksum where warranted." },
    "limitations": { "type": ["string", "null"] }
  }
}
