{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Selected Controls - Universal Audit spec v2.2",
  "type": "object",
  "required": ["schema_version", "spec_version", "audit_id", "tier", "profile", "controls"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "spec_version": { "const": "2.2" },
    "audit_id": { "type": "string", "pattern": "^AUD-[A-Z0-9]+-\\d{8}-\\d{3}$" },
    "tier": { "enum": ["rapid", "standard", "deep"] },
    "profile": { "enum": ["P1", "P2", "P3", "P4", "P5", "P6"] },
    "standard_tier_denominator": {
      "type": ["integer", "null"],
      "description": "Required for rapid audits: count of applicable R+S controls under the same applicability decisions, for cross-tier coverage disclosure (spec 13.3)."
    },
    "systemic_risk_categories": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Category keys where a verified systemic-risk record (spec 13.5, all four conditions) exists."
    },
    "controls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["control_id", "criticality", "status"],
        "properties": {
          "control_id": { "type": "string", "pattern": "^[A-Z0-9]+-[A-Z0-9]+-\\d{3}$" },
          "category": {
            "type": ["string", "null"],
            "description": "Optional override; normally derived from spec A.0 mapping."
          },
          "criticality": { "enum": ["C1", "C2", "C3"] },
          "tier": { "enum": ["R", "S", "D"] },
          "status": { "enum": ["PASS", "FAIL", "WARN", "NOTE", "UNVERIFIED", "NOT_APPLICABLE"] },
          "severity": { "enum": ["Critical", "High", "Medium", "Low", null] },
          "na_justification": { "type": ["string", "null"] },
          "evidence_ids": { "type": "array", "items": { "type": "string" } },
          "finding_ids": { "type": "array", "items": { "type": "string" } }
        },
        "allOf": [
          {
            "if": { "properties": { "status": { "enum": ["FAIL", "WARN"] } } },
            "then": { "required": ["severity"] }
          },
          {
            "if": { "properties": { "status": { "const": "NOT_APPLICABLE" } } },
            "then": { "required": ["na_justification"] }
          },
          {
            "if": { "properties": { "status": { "const": "WARN" } } },
            "then": { "properties": { "severity": { "enum": ["High", "Medium", "Low"] } } }
          }
        ]
      }
    }
  }
}
