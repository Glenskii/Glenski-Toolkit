{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Finding - Universal Audit spec v2.2, Section 9 twenty-field standard",
  "type": "object",
  "required": [
    "schema_version", "audit_id", "finding_id", "control_ids", "title", "status",
    "severity", "likelihood", "confidence", "evidence_ids", "affected_version",
    "environment", "observable_condition", "expected_condition", "technical_risk",
    "business_impact", "scope_of_impact", "recommended_fix", "remediation_effort",
    "owner", "verification", "residual_risk"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "audit_id": { "type": "string" },
    "finding_id": { "type": "string", "pattern": "-F\\d{3}$" },
    "control_ids": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "title": { "type": "string", "maxLength": 120 },
    "cross_tags": { "type": "array", "items": { "type": "string" } },
    "status": { "enum": ["FAIL", "WARN", "NOTE", "UNVERIFIED"] },
    "severity": { "enum": ["Critical", "High", "Medium", "Low", "Informational"] },
    "likelihood": { "enum": ["High", "Medium", "Low", "Unknown"] },
    "confidence": { "enum": ["High", "Medium", "Low"] },
    "evidence_ids": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "affected_version": { "type": "string" },
    "environment": { "type": "string" },
    "preconditions": { "type": ["string", "null"] },
    "observable_condition": { "type": "string" },
    "expected_condition": { "type": "string" },
    "technical_risk": { "type": "string" },
    "business_impact": { "type": "string" },
    "scope_of_impact": { "type": ["string", "null"] },
    "recommended_fix": { "type": "string" },
    "alternative_control": { "type": ["string", "null"] },
    "remediation_effort": { "enum": ["Small", "Medium", "Large", "Requires discovery"] },
    "owner": { "type": "string" },
    "verification": { "type": "string" },
    "residual_risk": { "type": ["string", "null"] },
    "challenge_outcome": {
      "enum": ["UPHELD", "MODIFIED", "REJECTED", "NEEDS_MORE_EVIDENCE", null]
    },
    "reaudit_state": {
      "enum": ["OPEN", "PARTIALLY_REMEDIATED", "REMEDIATED", "ACCEPTED", "REGRESSED", "NOT_REPRODUCIBLE", null]
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "WARN" } } },
      "then": { "properties": { "severity": { "enum": ["High", "Medium", "Low"] } } }
    }
  ]
}
