# ============================================================
# VIBE SECURITY AUDIT — Environment Configuration
# Copy this file to .env.test and fill in your values.
# NEVER commit .env.test to version control.
# ============================================================

# Your ASGI app import path
# Format: module.path:app_variable
APP_IMPORT_PATH=your_app.main:app

# Routes — update to match your actual application routes
TEST_PUBLIC_ROUTE=/
TEST_PROTECTED_ROUTE=/api/me
TEST_ADMIN_ROUTE=/api/admin
TEST_AUTH_LOGIN_ROUTE=/auth/login
TEST_AUTH_REGISTER_ROUTE=/auth/register
TEST_ERROR_ROUTE=/debug/trigger-error
TEST_404_ROUTE=/this-route-does-not-exist
TEST_ERROR_SIM_ROUTE=/error-test

# IDOR test route — use {target_id} as the placeholder
TEST_IDOR_ROUTE_TEMPLATE=/api/user/{target_id}

# Test credentials — use dedicated test accounts ONLY
TEST_USERNAME=test_user
TEST_PASSWORD=test_password
TEST_ADMIN_USERNAME=admin_user
TEST_ADMIN_PASSWORD=admin_password

# Rate limit threshold — set to your app's actual configured limit
TEST_RATE_LIMIT_THRESHOLD=20

# CORS — set to a hostile origin for rejection tests
TEST_HOSTILE_ORIGIN=https://evil.example.com
TEST_ALLOWED_ORIGIN=https://yourdomain.com
